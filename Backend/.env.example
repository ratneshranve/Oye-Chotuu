# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>

# JWT Configuration
JWT_ACCESS_SECRET=your_jwt_access_secret_here
JWT_ACCESS_EXPIRES=1d
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_REFRESH_EXPIRES=30d

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Realtime & Queue Configuration
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379
BULLMQ_ENABLED=false

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=120
BCRYPT_SALT_ROUNDS=10
UPLOAD_PATH=uploads/

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password
EMAIL_FROM="Your App Name <noreply@yourdomain.com>"

# Google Maps API Configuration
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Admin registration safeguard
ADMIN_REGISTRATION_CODE=your_secure_admin_registration_code
ADMIN_NOTIFICATION_EMAILS=admin@example.com

# Razorpay Configuration
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Password reset configuration
PASSWORD_RESET_OTP_EXPIRY_MINUTES=10
PASSWORD_RESET_MAX_ATTEMPTS=5
PASSWORD_RESET_TOKEN_EXPIRY_MINUTES=30

# Socket.io Configuration
SOCKET_CORS_ORIGIN=http://localhost:5173

# Firebase Configuration
FIREBASE_SERVICE_ACCOUNT_PATH=./config/firebase-service-account.json
# Alternative: Raw JSON string for Firebase Service Account
FIREBASE_SERVICE_ACCOUNT={}
FIREBASE_DATABASE_URL=https://your-project-id.firebaseio.com/

# SMS INDIA HUB CONFIGURATION
USE_DEFAULT_OTP=true
SMS_INDIA_HUB_USERNAME=your_username
SMS_INDIA_HUB_API_KEY=your_api_key
SMS_INDIA_HUB_SENDER_ID=your_sender_id
SMS_INDIA_HUB_DLT_TEMPLATE_ID=1007801291964877107

# OTP CONFIGURATION
OTP_EXPIRY_MINUTES=10
OTP_EXPIRY_SECONDS=300
OTP_MAX_ATTEMPTS=3
OTP_RATE_LIMIT=300
OTP_RATE_WINDOW=600
OTP_EXPIRY=5m
